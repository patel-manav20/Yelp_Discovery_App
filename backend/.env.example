# =============================================================================
# Restaurant Lab — Backend environment
# Copy to .env and fill in values:  cp .env.example .env
# =============================================================================

# --- Database (required) ---
# Create an empty schema first, e.g. CREATE DATABASE restaurant_lab ...
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/restaurant_lab

# --- JWT (required) ---
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS (required for browser frontend) ---
# Comma-separated origins, no spaces after commas
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Debugging ---
# Set true to echo SQL in the terminal
DEBUG=false

# --- Optional: Yelp Fusion API ---
# Needed for POST /restaurants/import-from-yelp, GET /restaurants/yelp proxy routes,
# and supplemental AI search hits.
# Sign up: https://www.yelp.com/developers/documentation/v3/authentication
YELP_API_KEY=

# --- Optional: Google AI Gemini (REST via httpx in app) ---
# Powers structured filter extraction + natural language replies in POST /ai-assistant/chat
# https://ai.google.dev/
GEMINI_API_KEY=
# Examples: gemini-2.0-flash, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# --- Optional: Tavily Search (web context for AI assistant replies) ---
# https://tavily.com/
TAVILY_API_KEY=
