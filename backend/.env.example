# Copy to .env: cp .env.example .env

# Create the DB/schema first (e.g. restaurant_lab), then set the URL below.
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/restaurant_lab
# Generate a strong value: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated origins; no spaces after commas (add your deployed frontend URL here).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEBUG=false

# Optional: Yelp import/proxy; Gemini + Tavily for POST /ai-assistant/chat
YELP_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
TAVILY_API_KEY=
