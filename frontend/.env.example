# Backend API base URL (no trailing slash). Axios uses this for all requests.
# Default if unset: http://localhost:8000
VITE_API_URL=http://localhost:8000

# Explore map uses OpenStreetMap tiles (free, no API key). For high-traffic production,
# host your own tiles or use a commercial tile provider per OSM policy.
