# MongoDB
MONGODB_URL=mongodb://mongodb:27017/yelp_discovery
DB_NAME=yelp_discovery

# Auth / app
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# External APIs
YELP_API_KEY=replace-with-yelp-api-key
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
TAVILY_API_KEY=replace-with-tavily-api-key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Service container ports (Part 1.1)
USER_REVIEWER_SERVICE_URL=http://user-reviewer-service:8001
RESTAURANT_OWNER_SERVICE_URL=http://restaurant-owner-service:8002
RESTAURANT_SERVICE_URL=http://restaurant-service:8003
REVIEW_SERVICE_URL=http://review-service:8004
